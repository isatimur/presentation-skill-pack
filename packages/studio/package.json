{
  "name": "@presentation-skill-pack/studio",
  "version": "0.1.1",
  "description": "Browser-based editor studio for presentation-skill-pack decks: edit, live-preview, and export to HTML or PowerPoint (.pptx).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:web": "vite build --base=/studio/ --outDir ../../web/studio --emptyOutDir",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@presentation-skill-pack/export": "workspace:*",
    "mustache": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@presentation-skill-pack/core": "workspace:*",
    "@types/mustache": "^4.2.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
