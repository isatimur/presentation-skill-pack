{
  "name": "@presentation-skill-pack/install",
  "version": "0.1.2",
  "description": "One-command installer for presentation-skill-pack adapters.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "presentation-skill-pack-install": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/adapters && cp -R ../../adapters/. dist/adapters/",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@presentation-skill-pack/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isatimur/presentation-skill-pack.git"
  },
  "homepage": "https://presentation-skill-pack.vercel.app",
  "bugs": "https://github.com/isatimur/presentation-skill-pack/issues"
}
