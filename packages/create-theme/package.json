  "dependencies": {
    "commander": "^12.0.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": { "node": ">=20.0.0" },
  "publishConfig": { "access": "public" }
}
