{
  "name": "@presentation-skill-pack/create-theme",
  "version": "0.1.0",
  "description": "Scaffold a new presentation-skill-pack theme package.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "create-presentation-theme": "./dist/index.js" },
  "files": ["dist", "src/template"],
  "scripts": {
