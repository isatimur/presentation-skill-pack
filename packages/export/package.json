{
  "name": "@presentation-skill-pack/export",
  "version": "0.2.0",
  "description": "Export a presentation-skill-pack deck JSON spec to native, editable PowerPoint (.pptx) — also opens in Keynote and imports into Google Slides.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@presentation-skill-pack/core": "workspace:*",
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isatimur/presentation-skill-pack.git"
  },
  "homepage": "https://presentation-skill-pack.vercel.app",
  "bugs": "https://github.com/isatimur/presentation-skill-pack/issues"
}
